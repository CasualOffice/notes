# Casual Note — example environment configuration.
# Copy to `.env` for local development. Nothing here is required for the
# offline core paths (network is touched only by model-download and updater,
# and only with explicit user consent — see CLAUDE.md invariants).

# --- Logging (local only; never network-shipped) ---
# tracing-subscriber EnvFilter directive.
RUST_LOG=info,casualnote=debug

# --- Frontend dev server (Vite) ---
VITE_DEV_PORT=5173

# --- Model registry (consented network service; blank = offline / USB import only) ---
# Signed model CDN base URL. Leave empty to disable all download attempts.
CASUALNOTE_MODEL_REGISTRY_URL=

# --- Updater (consented network service; blank = disabled) ---
CASUALNOTE_UPDATE_FEED_URL=

# NOTE: The SQLCipher database key is NEVER stored here or in any file.
# It lives only in the OS keystore (Keychain / Credential Manager / Secret Service).
